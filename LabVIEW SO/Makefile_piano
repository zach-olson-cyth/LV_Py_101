# Makefile for piano_synth.so
# Target: NI Linux RT x86-64 (cRIO-9040)
CC     ?= x86_64-linux-gnu-gcc
CFLAGS := -O2 -fPIC -Wall -Wextra -std=c99 -D_GNU_SOURCE
TARGET := piano_synth.so
SRC    := piano_synth.c

.PHONY: all test clean

all: $(TARGET)

$(TARGET): $(SRC)
	$(CC) $(CFLAGS) -shared -o $@ $< -lm
	@echo "Built $(TARGET)"

test: $(SRC)
	$(CC) $(CFLAGS) -DPIANO_SMOKE_TEST -o piano_synth_test $< -lm
	./piano_synth_test

clean:
	rm -f $(TARGET) piano_synth_test
